# Callibrator Backend - Environment Configuration
# Copy this file to .env and fill in the values

# ==========================================
# DATABASE (PostgreSQL or MySQL)
# ==========================================
DB_HOST=localhost
DB_PORT=5432
DB_NAME=callibrator
DB_USER=postgres
DB_PASS=your_db_password
DB_DIALECT=postgres
DB_SSL=false
# DB_SSL_CA=/path/to/ca-cert.pem
# DB_SSL_REJECT_UNAUTHORIZED=true

# ==========================================
# DATABASE CONNECTION POOL
# ==========================================
# DB_POOL_MAX=10          — Max connections (default: 10 dev / 20 prod)
# DB_POOL_MIN=2           — Min connections (default: 2)
# DB_POOL_ACQUIRE_TIMEOUT=30000 — Max ms to wait for a connection (default: 30000)
# DB_POOL_IDLE_TIMEOUT=10000      — Max ms an idle connection can remain (default: 10000)

# ==========================================
# REDIS
# ==========================================
REDIS_URL=redis://localhost:6379
# Or use host/port:
# REDIS_HOST=localhost
# REDIS_PORT=6379

# ==========================================
# RABBITMQ
# ==========================================
RABBITMQ_URL=amqp://localhost:5672
# RABBITMQ_PORT=5672

# ==========================================
# JWT
# ==========================================
JWT_ACCESS_SECRET=change-this-to-a-long-random-string
JWT_ACCESS_EXPIRED=15m
JWT_REFRESH_SECRET=change-this-to-another-long-random-string
JWT_REFRESH_EXPIRED=7d

# ==========================================
# APP
# ==========================================
NODE_ENV=development
HOST_URL=http://localhost:5000
APP_STORAGE_PATH=./storage
MAX_FILE_SIZE=10485760
# 10MB in bytes

# ==========================================
# EMAIL (Nodemailer)
# ==========================================
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USER=your-email@gmail.com
MAIL_PASSWORD=your-app-password
MAIL_FROM=noreply@callibrator.app

# ==========================================
# SUPER ADMIN
# ==========================================
SUPER_ADMIN_ROLE_ID=uuid-here

# ==========================================
# CRON SCHEDULERS (optional, use node-cron format)
# ==========================================
# SESSION_CLEANUP_SCHEDULER=0 2 * * *
# BACKUP_SCHEDULER=0 3 * * 0
