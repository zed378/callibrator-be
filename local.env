# App
PORT=3000
SECRET=generateRandomSecretKey
APP_STORAGE_PATH=/app # this for define persistent storage root

# Cors origins
CORS_ORIGIN=http://localhost:3000,http//:localhost:5000

# JWT
JWT_ACCESS_SECRET=generateRandomSecretKey
JWT_ACCESS_EXPIRED=10m
JWT_REFRESH_SECRET=generateRandomSecretKey
JWT_REFRESH_EXPIRED=7d
JWT_EXPIRED=1d

# env
NODE_ENV=development # it should be development or production

# Host
HOST_URL=http://localhost:3000

# DB
DB_HOST=localhost # use 'postgres' for deploy and 'localhost' for dev 
DB_PORT=5432
DB_NAME=boilerplate
DB_USER=boilerplate
DB_PASS=supersecret
DB_DIALECT=postgres
DB_SSL=false

# Mail setting
MAIL_HOST=your_mail_server
MAIL_PORT=465
MAIL_USER=your@mail.com
MAIL_PASSWORD=your_mail_password
MAIL_SECURE=true
MAIL_FROM="Webmaster <you@mail.com>"

# Cron expression
BACKUP_SCHEDULER="0 0 * * *"

# Session Cleanup Scheduler
# Cron expression for automatically deleting expired sessions
# Default: Daily at 2:00 AM
SESSION_CLEANUP_SCHEDULER="0 2 * * *"

# Redis
REDIS_URL=redis://localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379

# RabbitMQ
RABBITMQ_URL=amqp://localhost:5672
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USER=guest
RABBITMQ_PASS=guest
