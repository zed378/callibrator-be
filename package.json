{
  "name": "express-boilerplate",
  "version": "1.0.0",
  "description": "Generate template and config so it will auto provisioning in Harvester.",
  "keywords": [
    "docker",
    "nodejs",
    "expressjs",
    "backend"
  ],
  "bin": "index.js",
  "pkg": {
    "assets": [
      "src/templates/**/*",
      "node_modules/swagger-ui-dist/**/*",
      "uploads/**/*",
      "swagger.json"
    ],
    "scripts": [
      "src/**/*.js"
    ],
    "targets": [
      "node24-linux-x64",
      "node24-win-x64"
    ],
    "outputPath": "dist"
  },
  "license": "MIT",
  "author": "zed378",
  "type": "commonjs",
  "main": "index.js",
  "scripts": {
    "test": "jest --forceExit",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "start": "node index.js",
    "dev": "nodemon index.js",
    "build": "bun build index.js --compile --loader:.html=text --target bun-linux-x64 --outfile dist/boilerplate",
    "swagger:generate": "node src/utils/generateSwagger.js"
  },
  "dependencies": {
    "axios": "^1.16.0",
    "bcryptjs": "^3.0.3",
    "compression": "^1.8.1",
    "connect-timeout": "^1.9.1",
    "cors": "^2.8.6",
    "crypto": "^1.0.1",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.0",
    "fs-extra": "^11.3.4",
    "helmet": "^8.1.0",
    "hpp": "^0.2.3",
    "ioredis": "^5.6.1",
    "amqplib": "^0.10.5",
    "joi": "^18.2.1",
    "jsonwebtoken": "^9.0.3",
    "jszip": "^3.10.1",
    "markdown-it": "^14.1.1",
    "moment": "^2.30.1",
    "moment-timezone": "^0.6.2",
    "morgan": "^1.10.1",
    "multer": "^2.1.1",
    "mustache": "^4.2.0",
    "node-cron": "^4.2.1",
    "nodemailer": "^8.0.7",
    "pg": "^8.20.0",
    "pg-hstore": "^2.3.4",
    "puppeteer": "^25.0.4",
    "randomstring": "^1.3.1",
    "rotating-file-stream": "^3.2.9",
    "sanitize-html": "^2.17.3",
    "sequelize": "^6.37.8",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "uuid": "^14.0.0",
    "winston": "^3.19.0",
    "winston-daily-rotate-file": "^5.0.0",
    "xss": "^1.0.15"
  },
  "devDependencies": {
    "jest": "^30.4.2",
    "markdown-pdf": "^11.0.0",
    "nodemon": "^3.1.14"
  }
}
