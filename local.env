# =============================================================================
# BACKEND LOCAL DEVELOPMENT CONFIGURATION
# =============================================================================
# IMPORTANT: Never commit secrets to version control.
# Use .env (gitignored) for actual secrets. This file contains placeholders only.
# =============================================================================

# -----------------------------------------------------------------------------
# App
# -----------------------------------------------------------------------------
PORT=5000
# SECRET must be at least 32 characters. Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SECRET=CHANGE_ME_GENERATE_RANDOM_SECRET_KEY_32_CHARS_MINIMUM
APP_STORAGE_PATH=/app

# -----------------------------------------------------------------------------
# CORS Origins
# -----------------------------------------------------------------------------
CORS_ORIGIN=http://localhost:5000,http://localhost:3000,http://localhost:5173,http://10.1.101.50:3000,http://localhost:3030

# -----------------------------------------------------------------------------
# JWT Secrets
# -----------------------------------------------------------------------------
# JWT_ACCESS_SECRET: Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_ACCESS_SECRET=CHANGE_ME_GENERATE_RANDOM_ACCESS_SECRET_KEY
JWT_ACCESS_EXPIRED=1d
# JWT_REFRESH_SECRET: Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_REFRESH_SECRET=CHANGE_ME_GENERATE_RANDOM_REFRESH_SECRET_KEY
JWT_REFRESH_EXPIRED=7d
JWT_EXPIRED=1d

# -----------------------------------------------------------------------------
# Environment
# -----------------------------------------------------------------------------
NODE_ENV=development

# -----------------------------------------------------------------------------
# Host
# -----------------------------------------------------------------------------
HOST_URL=http://localhost:5000

# -----------------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------------
DB_HOST=localhost
DB_PORT=5432
DB_NAME=boilerplate
DB_USER=boilerplate
# DB_PASS: Set your actual PostgreSQL password here
DB_PASS=CHANGE_ME_SET_ACTUAL_POSTGRES_PASSWORD
DB_DIALECT=postgres
DB_SSL=false

# -----------------------------------------------------------------------------
# Mail Settings
# -----------------------------------------------------------------------------
MAIL_HOST=mail.growthindonesia.id
MAIL_PORT=465
MAIL_USER=dev@growthindonesia.id
# MAIL_PASSWORD: Set your actual mail password here
MAIL_PASSWORD=CHANGE_ME_SET_ACTUAL_MAIL_PASSWORD
MAIL_SECURE=true
MAIL_FROM="Webmaster <kembedt@gmail.com>"

# -----------------------------------------------------------------------------
# Cron Expressions
# -----------------------------------------------------------------------------
BACKUP_SCHEDULER="0 0 * * *"

# Session Cleanup Scheduler
# Cron expression for automatically deleting expired sessions
# Default: Daily at 2:00 AM
SESSION_CLEANUP_SCHEDULER="0 2 * * *"

# -----------------------------------------------------------------------------
# Redis
# -----------------------------------------------------------------------------
REDIS_URL=redis://localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379

# -----------------------------------------------------------------------------
# RabbitMQ
# -----------------------------------------------------------------------------
RABBITMQ_URL=amqp://localhost:5672
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USER=guest
RABBITMQ_PASS=guest